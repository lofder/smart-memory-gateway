# === Required: Embedding API Key ===
# At least one of these must be set for the primary Gemini embedder:
GOOGLE_API_KEY=your-google-api-key-here
# GEMINI_API_KEY=
# GOOGLE_VERTEX_API_KEY=

# === Required: LLM API Key ===
# Used by Mem0 for inference and by maintenance for re-extraction:
# LLM_API_KEY=your-llm-api-key-here
# Or if using OpenAI directly:
# OPENAI_API_KEY=your-openai-api-key-here

# === Optional: Fallback Embedding Provider ===
# EMBEDDING_API_KEY=your-embedding-proxy-key

# === Qdrant (only change if not using docker-compose) ===
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
