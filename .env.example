# === Required: Embedding API Key ===
# At least one of these must be set for the primary Gemini embedder
GOOGLE_API_KEY=your-google-api-key-here
# GEMINI_API_KEY=
# GOOGLE_VERTEX_API_KEY=

# === Optional: LLM + Fallback Embedder ===
# Used by Mem0 for inference and as fallback embedding provider
# LINGYUN_GEMINI_API_KEY=your-proxy-api-key-here

# === Qdrant (only change if not using docker-compose) ===
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
